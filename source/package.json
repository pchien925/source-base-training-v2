{
    "name": "cms-template",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "postinstall": "cd .. && husky install source/.husky",
        "start": "env-cmd -f ./env/.dev craco start",
        "prebuild:dev": "rm -rf build",
        "build:dev": "env-cmd -f ./env/.dev craco build",
        "build:beta": "env-cmd -f ./env/.beta craco build",
        "prebuild:prod": "rm -rf build",
        "build:production": "env-cmd -f ./env/.production craco build",
        "prebuild:staging": "rm -rf build",
        "build:staging": "env-cmd -f ./env/.staging craco build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "lint": "eslint \"src/**/*.js\" --fix",
        "format": "prettier --write \"src/**/*.js\"",
        "i18n": "extract-react-intl-messages -l=en -d en -o src/locales --flat src/**/*.js"
    },
    "dependencies": {
        "@commitlint/cli": "^17.0.0",
        "@commitlint/config-conventional": "^17.3.0",
        "@craco/craco": "^7.0.0",
        "@dnd-kit/core": "^6.1.0",
        "@dnd-kit/sortable": "^7.0.2",
        "@dnd-kit/utilities": "^3.2.1",
        "@itz/react-cms-element": "^1.0.21",
        "@itz/react-core": "^1.0.2",
        "@itz/react-utils": "^1.0.13",
        "@jackwilsdon/craco-use-babelrc": "^1.0.0",
        "@radix-ui/react-dialog": "^1.1.2",
        "@tabler/icons-react": "^2.39.0",
        "@testing-library/jest-dom": "^6.4.0",
        "@testing-library/react": "^14.0.0",
        "@testing-library/user-event": "^14.5.0",
        "@tippyjs/react": "^4.2.6",
        "@videojs/themes": "^1.0.1",
        "antd": "^5.10.1",
        "antd-img-crop": "^4.13.0",
        "babel-plugin-react-intl-auto": "^3.3.0",
        "buffer": "^6.0.3",
        "classnames": "^2.3.2",
        "crypto-js": "^4.2.0",
        "dayjs": "^1.11.7",
        "env-cmd": "^10.1.0",
        "eslint-plugin-prettier": "^4.2.1",
        "extract-react-intl-messages": "^4.1.1",
        "flexsearch": "^0.7.43",
        "husky": "^8.0.2",
        "immer": "^9.0.16",
        "jwt-decode": "^4.0.0",
        "lint-staged": "^13.1.0",
        "lodash": "^4.17.21",
        "moment": "^2.30.1",
        "node-forge": "^1.3.1",
        "pako": "^2.1.0",
        "prettier-eslint": "^16.3.0",
        "query-string": "^8.0.3",
        "quill-image-drop-and-paste": "^2.0.1",
        "quill-image-resize-module-react": "^3.0.0",
        "react": "^18.3.1",
        "react-color": "^2.19.3",
        "react-dom": "^18.3.1",
        "react-icons": "^5.3.0",
        "react-intl": "^6.0.3",
        "react-modern-drawer": "^1.2.0",
        "react-quill": "^2.0.0",
        "react-redux": "^8.0.5",
        "react-router-dom": "^6.5.0",
        "react-scripts": "5.0.1",
        "react-swipeable-list": "^1.10.0",
        "react-virtualized-auto-sizer": "^1.0.24",
        "react-window": "^1.8.10",
        "react-window-infinite-loader": "^1.0.9",
        "recharts": "^2.8.0",
        "redux": "^4.2.0",
        "redux-saga": "^1.2.2",
        "reselect": "^4.1.7",
        "sass": "^1.57.1",
        "unidecode": "^0.1.8",
        "video.js": "^7.21.6",
        "videojs-contrib-ads": "^6.9.0",
        "videojs-contrib-quality-levels": "^2.1.0",
        "videojs-hls-quality-selector": "^1.1.4",
        "videojs-markers": "^1.0.1",
        "videojs-playlist": "^4.3.1",
        "videojs-thumbnail-sprite": "^0.1.1",
        "web-vitals": "^2.1.4",
        "yup": "^0.32.11"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "lint-staged": {
        "*.js": [
            "npm run lint",
            "git add ."
        ]
    }
}
